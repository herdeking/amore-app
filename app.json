{
  "expo": {
    "name": "Amore",
    "slug": "amore-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.herdeking.amoreapp",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B6E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5150043080807634~8176811403",
          "iosAppId": "ca-app-pub-5150043080807634~8176811403"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "kotlinVersion": "2.1.20",
            "buildToolsVersion": "35.0.0",
            "gradlePluginVersion": "8.4.2",
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      "./plugins/withJitsiGradleFix.js",
      "./plugins/withWorkletsHermesFix.js"
    ],
    "splash": {
      "backgroundColor": "#FF4B6E",
      "resizeMode": "contain"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#FF4B6E"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59e42aa5-b8e5-486e-a571-46d92bb9a79c"
      }
    },
    "owner": "ghosted001"
  }
}
