{
  "expo": {
    "name": "Amore",
    "slug": "amore-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.herdeking.amoreapp",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B6E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#FF4B6E",
      "resizeMode": "contain"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#FF4B6E"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "308d78fc-4fed-46ac-ac52-463852455841"
      }
    },
    "owner": "amore01"
  }
}
