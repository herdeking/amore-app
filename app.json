{
  "expo": {
    "name": "Amore",
    "slug": "amore-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.herdeking.amoreapp",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B6E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5150043080807634~8176811403",
          "iosAppId": "ca-app-pub-5150043080807634~8176811403"
        }
      ]
    ],
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#FF4B6E",
      "resizeMode": "contain"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#FF4B6E"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d970a38d-c658-49ab-891c-f27ba7f33fe6"
      }
    },
    "owner": "checker001"
  }
}
