{
  "expo": {
    "name": "Amore",
    "slug": "amore-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.herdeking.amoreapp",
      "adaptiveIcon": {
        "backgroundColor": "#FF4B6E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "newArchEnabled": false,
    "owner": "amorec",
    "extra": {
      "eas": {
        "projectId": "a5dd444f-6992-4021-99a0-b0af870b64ef"
      }
    },
    "splash": {
      "backgroundColor": "#FF4B6E",
      "resizeMode": "contain"
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#FF4B6E"
    }
  }
}
